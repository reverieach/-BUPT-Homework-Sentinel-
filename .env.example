# 北邮作业通知系统 (BUPT Homework Sentinel)
#需要创建自己的.env文件并完整复制此文件所有内容或者直接重命名此文件为.env，再按需修改相关配置
# ==========================
# 必填核心配置（先填这里）学号和密码
# ==========================
SCHOOL_ID=
SCHOOL_PWD=

# 手动填你自己的云平台首页完整 URL
# 示例: https://ucloud.bupt.edu.cn/uclass/#/student/homePage?roleId=...
UCLOUD_HOME_URL=

# USER_ID 不是学号，是 undone 接口里的 userId。
# 建议留空：程序会尝试从 BLADE_AUTH 或 valid_headers.json 的 blade-auth 自动解析。
USER_ID=

# ==========================
# 推荐基础配置（一般保持默认）
# ==========================
SCHOOL_LOGIN_URL=https://auth.bupt.edu.cn/authserver/login?service=https://ucloud.bupt.edu.cn

#浏览器无头模式默认开启，卡住可设置为flase查看具体流程问题
PLAYWRIGHT_HEADLESS=true
CAPTURE_WAIT_SECONDS=5

API_BASE_URL=https://apiucloud.bupt.edu.cn
API_UNDONE_ENDPOINT=/ykt-site/site/student/undone
PAGE_SIZE=100

HEADER_FILE=valid_headers.json
STATE_FILE=homework_db.json

REQUEST_TIMEOUT_SEC=15
REQUEST_RETRIES=3
REQUEST_RETRY_DELAY_SEC=2
DISABLE_SYSTEM_PROXY=false
AUTO_REFRESH_HEADERS_ON_401=true

REMINDER_DAYS=2,1,0

# 可选：直接粘贴鉴权 token（建议不填，通过 --capture-headers 抓取，token刷新较快）
AUTHORIZATION=
BLADE_AUTH=

# ==========================
# 可选通知功能
# ==========================
# 可选渠道: console, desktop, markdown, wechat, pushplus, email, webhook
NOTIFY_CHANNELS=desktop,markdown
NOTIFY_EVENTS=NEW,DUE
NOTIFY_TITLE_PREFIX=[Homework Monitor]

# 本地 Markdown 提醒文件
MARKDOWN_OUTPUT_FILE=homework_reminders.md
MARKDOWN_APPEND=true

# 通用 Webhook
NOTIFY_WEBHOOK_URL=

# 企业微信机器人
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
WECHAT_WEBHOOK_URL=

# PushPlus（更简单的微信推送）
# 官网: https://www.pushplus.plus
PUSHPLUS_TOKEN=
PUSHPLUS_TOPIC=
PUSHPLUS_TEMPLATE=txt

# 邮件 (QQ SMTP 等)
# QQ 示例:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_STARTTLS=false
# SMTP_USERNAME=your@qq.com
# SMTP_PASSWORD=QQ邮箱SMTP授权码
# SMTP_FROM=your@qq.com
# SMTP_TO=to1@qq.com,to2@qq.com
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
